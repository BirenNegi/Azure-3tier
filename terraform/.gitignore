# This file should be in the terraform/ directory

# Ignore Terraform files
.terraform/
.terraform.lock.hcl
.terraform.tfstate*
*.tfstate*

# Ignore local state files
.terraform.tfstate
.terraform.tfstate.backup

# Ignore variable files with actual values (IMPORTANT!)
terraform.tfvars
*.auto.tfvars
!terraform.tfvars.example

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
*.plan

# Ignore crash log files
crash.log
crash.*.log

# Ignore excluded files
exclude/

# Ignore Mac .DS_Store files
.DS_Store

# Ignore editor files
.idea/
*.swp
*.swo
*~
.vscode/
*.code-workspace

# OS-specific
Thumbs.db
.env
.env.local
.env.*.local

# IDE
.project
.pydevproject
.settings/

# Password/secrets files
secrets.tfvars
secrets.auto.tfvars
*.secrets
.aws/
